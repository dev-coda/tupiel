# Backend env - copy to .env and adjust.
# For local dev with docker-compose.dev.yml (DB only):

# App database (local MySQL from docker-compose.dev.yml)
APP_DB_HOST=localhost
APP_DB_PORT=3308
APP_DB_NAME=tupiel_app
APP_DB_USER=tupiel_app
APP_DB_PASSWORD=localdev

# Inteligencia de Pacientes (CRM) — separate MySQL database; defaults match APP_* if unset
# IP_DB_HOST=localhost
# IP_DB_PORT=3308
IP_DB_NAME=tupiel_inteligencia
# IP_DB_USER=tupiel_app
# IP_DB_PASSWORD=localdev
# Existing dev MySQL volumes (before mysql-init was added): run once as root —
#   docker exec -i tupiel-mysql-dev mysql -uroot -p"$APP_DB_ROOT_PASSWORD" < backend/docker/mysql-init/01-inteligencia.sql

# Production DB (for reports - use real credentials or USE_LOCAL_DB)
# Option A: real production (read-only)
# DB_HOST=your-do-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=tupiel
# DB_USER=your_user
# DB_PASSWORD=your_password

# Option B: local dump (if you have a tupiel dump and run it in the same MySQL)
# USE_LOCAL_DB=true
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PORT=3306
# LOCAL_DB_NAME=tupiel
# LOCAL_DB_USER=root
# LOCAL_DB_PASSWORD=localroot

# HTTP port (must match frontend dev proxy target in frontend/proxy.conf.json).
# If something else already uses 3000 (e.g. Next.js), set e.g. PORT=3100 and point the proxy there.
PORT=3000
