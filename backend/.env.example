# Backend env - copy to .env and adjust.
# For local dev with docker-compose.dev.yml (DB only):

# App database (local MySQL from docker-compose.dev.yml)
APP_DB_HOST=localhost
APP_DB_PORT=3308
APP_DB_NAME=tupiel_app
APP_DB_USER=tupiel_app
APP_DB_PASSWORD=localdev

# Production DB (for reports - use real credentials or USE_LOCAL_DB)
# Option A: real production (read-only)
# DB_HOST=your-do-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=tupiel
# DB_USER=your_user
# DB_PASSWORD=your_password

# Option B: local dump (if you have a tupiel dump and run it in the same MySQL)
# USE_LOCAL_DB=true
# LOCAL_DB_HOST=localhost
# LOCAL_DB_PORT=3306
# LOCAL_DB_NAME=tupiel
# LOCAL_DB_USER=root
# LOCAL_DB_PASSWORD=localroot

# Optional
PORT=3000
