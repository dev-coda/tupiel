# TuPiel Deployment - Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#   nano .env
#
# ═══════════════════════════════════════════════════════════════════

# ─── Domain ───
# Your domain name (used for SSL certificate and nginx config)
DOMAIN=tupiel.nexo360.co

# ─── Server Connection ───
# IP address or hostname of your Vultr server (used by deploy.sh)
SERVER_IP=45.77.160.31
SERVER_USER=root

# ─── Production Database (DigitalOcean - READ ONLY) ───
# This is the live production database used for generating reports.
# The backend connects to it in read-only mode.
DB_HOST=tupiel-privado-do-user-1309890-0.j.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=tupiel
DB_USER=tupiel_u
DB_PASSWORD=kHcdSD0j[Gwk*Sz@

# ─── App Database (Local MySQL Container - READ/WRITE) ───
# This is the local MySQL container that stores application data:
# non-working days, monthly configs, employee budgets, saved reports.
# These passwords are for the MySQL container created by docker-compose.
APP_DB_PASSWORD=DidierTuPiel2025
APP_DB_ROOT_PASSWORD=DidierTuPiel2025

